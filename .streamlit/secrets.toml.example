# =============================================================================
# Tabular ML Lab — Streamlit Secrets Configuration
# =============================================================================
# Copy this file to secrets.toml and fill in values from your KeyCloak admin.
#
#   cp secrets.toml.example secrets.toml
#
# NEVER commit secrets.toml to version control.
# =============================================================================

[auth]
# Must match the redirect URI registered in your KeyCloak client.
# Use your actual deployment URL (not localhost) for production.
redirect_uri = "https://YOUR_APP_URL/oauth2callback"

# Random string used to secure the login session cookie.
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
cookie_secret = "GENERATE_A_RANDOM_SECRET_HERE"

[auth.keycloak]
# Client ID from KeyCloak (Clients → your client → Settings → Client ID)
client_id = "YOUR_KEYCLOAK_CLIENT_ID"

# Client secret from KeyCloak (Clients → your client → Credentials tab)
client_secret = "YOUR_KEYCLOAK_CLIENT_SECRET"

# OIDC discovery endpoint for your KeyCloak realm.
# Typically: https://<keycloak-host>/auth/realms/<realm>/.well-known/openid-configuration
# Your IT admin can provide this.
server_metadata_url = "https://YOUR_KEYCLOAK_DOMAIN/auth/realms/YOUR_REALM/.well-known/openid-configuration"
