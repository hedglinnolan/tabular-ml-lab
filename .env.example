# Tabular ML Lab - Enterprise Configuration

# Ollama Backend
# Point this to your institution's Ollama endpoint
OLLAMA_URL=http://ollama:11434

# Authentication
# Enable reverse proxy authentication (expects header from nginx/Apache)
AUTH_ENABLED=true
AUTH_HEADER=X-Remote-User

# Computational Resources
# Adjust based on available hardware:
#   standard - GTX 1080 Ti / consumer GPUs (default)
#   high_performance - Single A6000 / professional GPU
#   enterprise - Multi-GPU cluster with large RAM (A6000s, H100s, etc.)
COMPUTE_PROFILE=enterprise

# Streamlit Configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
